<% layout("/layouts/boilerplate") %>

<style>
    #filters-wrapper {
        margin-top: 1rem;
    }

    #filters {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        align-items: center;
        gap: 1.5rem;
        padding: 1rem 0;
        scrollbar-width: none;
    }

    #filters::-webkit-scrollbar {
        display: none;
    }

    .filter {
        text-align: center;
        opacity: 0.7;
        transition: all 0.3s ease-in-out;
        cursor: pointer;
        flex: 0 0 auto;
        min-width: 80px;
    }

    .filter:hover {
        opacity: 1;
        transform: scale(1.05);
    }

    .filter p {
        font-size: 0.8rem;
        margin-top: 0.4rem;
        margin-bottom: 0;
    }

    .filter-link {
        text-decoration: none;
        color: #222;
    }

    .filter-link:hover {
        color: #222;
    }

    .tax-info {
        display: none;
    }

    .tax-toggle-wrapper {
        display: flex;
        justify-content: center;
        margin: 1rem 0 1.5rem 0;
    }

    .tax-toggle {
        border: 1px solid #ccc;
        border-radius: 2rem;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        width: fit-content;
    }

    /* 🔥 CLEAN TEXT UI */

    .listing-title {
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 2px;
        color: #222;
    }

    .listing-location {
        font-size: 0.8rem;
        color: #717171;
        margin-bottom: 3px;
    }

    .listing-price {
        font-size: 0.9rem;
        font-weight: 600;
        color: #222;
    }

    .listing-price span {
        font-weight: 400;
        font-size: 0.8rem;
        color: #717171;
    }
</style>

<div id="filters-wrapper">
    <div id="filters">

        <div class="filter">
            <a href="/listings" class="filter-link">
                <div><i class="fa-solid fa-border-all"></i></div>
                <p>All</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=Trending" class="filter-link">
                <div><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=Rooms" class="filter-link">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=Iconic%20Cities" class="filter-link">
                <div><i class="fa-solid fa-city"></i></div>
                <p>Iconic Cities</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=Mountains" class="filter-link">
                <div><i class="fa-solid fa-mountain"></i></div>
                <p>Mountains</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=Castles" class="filter-link">
                <div><i class="fa-brands fa-fort-awesome"></i></div>
                <p>Castles</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=Amazing%20Pools" class="filter-link">
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amazing Pools</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=Camping" class="filter-link">
                <div><i class="fa-solid fa-campground"></i></div>
                <p>Camping</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=Farms" class="filter-link">
                <div><i class="fa-solid fa-tractor"></i></div>
                <p>Farms</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=Arctic" class="filter-link">
                <div><i class="fa-regular fa-snowflake"></i></div>
                <p>Arctic</p>
            </a>
        </div>

    </div>

    <div class="tax-toggle-wrapper">
        <div class="tax-toggle">
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                <label class="form-check-label ms-2">
                    Display total after taxes
                </label>
            </div>
        </div>
    </div>
</div>

<div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-2 row-cols-1">
    <% for(let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card col listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top">
                <div class="card-body">

                    <!-- 🔥 CLEAN TEXT -->
                    <p class="listing-title"><%= listing.title %></p>

                    <p class="listing-location">
                        <%= listing.location %>, <%= listing.country %>
                    </p>

                    <p class="listing-price">
                        ₹ <%= listing.price.toLocaleString("en-IN") %>
                        <span>/ night</span>
                        <span class="tax-info"> · incl. GST</span>
                    </p>

                </div>
            </div>
        </a>
    <% } %>
</div>

<script>
    const taxSwitch = document.getElementById("flexSwitchCheckDefault");

    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");

        for (let info of taxInfo) {
            info.style.display = (info.style.display !== "inline") ? "inline" : "none";
        }
    });
</script>